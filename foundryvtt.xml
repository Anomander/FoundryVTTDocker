<?xml version="1.0"?>
<Container version="2">
  <Name>foundryvtt</Name>

  <!--
    Update this to the version tag printed by GitHub Actions after each build.
    Format: ghcr.io/Anomander/foundryvtt:<version>
  -->
  <Repository>ghcr.io/anomander/foundryvtt:13.351</Repository>
  <Registry>https://ghcr.io</Registry>

  <!--
    Hosting this file on GitHub lets Unraid load it directly by URL.
    Community Applications → "Add template from URL" → paste the raw GitHub URL.
  -->
  <TemplateURL>https://raw.githubusercontent.com/Anomander/FoundryVTTDocker/main/foundryvtt.xml</TemplateURL>

  <!-- Foundry VTT official icon -->
  <Icon>https://foundryvtt.com/static/assets/icons/fvtt.png</Icon>

  <Overview>
    Foundry Virtual Tabletop – self-hosted tabletop RPG game server.&#xA;&#xA;
    This image is built from the official Foundry release zip via GitHub Actions and published to ghcr.io.&#xA;
    See https://github.com/Anomander/FoundryVTTDocker for upgrade instructions.
  </Overview>

  <Category>GameServers:</Category>

  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>

  <!-- Opens Foundry in the browser when you click the container icon in Unraid -->
  <WebUI>http://[IP]:[PORT:30000]/</WebUI>

  <Support>https://github.com/Anomander/FoundryVTTDocker</Support>
  <Project>https://foundryvtt.com</Project>

  <!-- ── Ports ──────────────────────────────────────────────────────────── -->
  <Config
    Name="Web Port"
    Target="30000"
    Default="30000"
    Mode="tcp"
    Description="Host port Foundry listens on. Point your reverse proxy here. Change only the left (host) side if 30000 is already in use."
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">30000</Config>

  <!-- ── Paths ─────────────────────────────────────────────────────────── -->
  <Config
    Name="Data Path"
    Target="/data"
    Default="/mnt/user/appdata/foundryvtt"
    Mode="rw"
    Description="Host path for Foundry user data: worlds, modules, systems, and config. This directory survives container upgrades."
    Type="Path"
    Display="always"
    Required="true"
    Mask="false">/mnt/user/appdata/foundryvtt</Config>

  <!-- ── Environment Variables ─────────────────────────────────────────── -->
  <Config
    Name="Admin Key"
    Target="FOUNDRY_ADMIN_KEY"
    Default=""
    Mode=""
    Description="Password for the Foundry /setup admin page. Set a strong value before first run."
    Type="Variable"
    Display="always"
    Required="true"
    Mask="true"></Config>

</Container>
